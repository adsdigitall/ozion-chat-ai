# Produção
NODE_ENV=production
PORT=3000

# Supabase - configure no Vercel Dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Meta WhatsApp
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=ozion_verify_token

# Groq (grátis) - configure via Vercel dashboard
GROQ_API_KEY=

# DeepSeek (quase grátis) - configure via Vercel dashboard
DEEPSEEK_API_KEY=

# Segurança - configure no Vercel Dashboard
JWT_SECRET=your_random_jwt_secret_at_least_32_chars
SESSION_SECRET=your_random_session_secret

# URLs
APP_URL=https://app.ozion.com.br
API_URL=https://api.ozion.com.br
