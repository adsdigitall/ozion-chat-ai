{
  "name": "ozion-chat-ai",
  "version": "1.0.0",
  "description": "WhatsApp CRM with AI Agents",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "build": "esbuild server/index.ts --bundle --platform=node --format=esm --outfile=dist/server/index.js '--external:./node_modules/*' --external:better-sqlite3",
    "start": "node dist/server/index.js",
    "deploy": "bash scripts/deploy.sh",
    "deploy:staging": "bash scripts/deploy.sh staging",
    "deploy:production": "bash scripts/deploy.sh production",
    "backup": "bash scripts/backup.sh",
    "backup:full": "bash scripts/backup.sh full",
    "backup:db": "bash scripts/backup.sh database",
    "rollback": "bash scripts/rollback.sh",
    "changelog": "bash scripts/changelog.sh",
    "seed": "tsx seed.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.5.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
