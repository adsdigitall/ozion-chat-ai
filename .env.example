# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ozion_chat
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# JWT
JWT_SECRET=your_random_jwt_secret_at_least_32_chars

# Facebook/Meta App
FACEBOOK_APP_ID=your_app_id
FACEBOOK_APP_SECRET=your_app_secret
FACEBOOK_CONFIG_ID=your_config_id
FACEBOOK_SOLUTION_ID=your_solution_id

# OAuth
OAUTH_REDIRECT_URI=http://localhost:3000/api/whatsapp/oauth/callback
OAUTH_STATE_SECRET=your_random_state_secret

# Webhook
WEBHOOK_VERIFY_TOKEN=your_verify_token_random
WEBHOOK_APP_SECRET=your_app_secret_for_validation

# Meta Conversions API
META_CAPI_DATASET_ID=your_dataset_id
META_CAPI_ACCESS_TOKEN=your_capi_access_token

# Encryption (for storing tokens)
ENCRYPTION_KEY=your_32_char_encryption_key

# Base URL
BASE_URL=http://localhost:3000
