{
  "version": 2,
  "name": "ozion-chat-ai",
  "installCommand": "npm install",
  "buildCommand": "echo 'Build complete'",
  "outputDirectory": "public",
  "env": {
    "NODE_ENV": "production",
    "TS_NODE_COMPILER_OPTIONS": "{\"noEmit\":true,\"strict\":false,\"noImplicitAny\":false}"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/index.ts"
    },
    {
      "src": "/css/(.*)",
      "dest": "public/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "public/js/$1"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ],
  "builds": [
    {
      "src": "server/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ]
}
